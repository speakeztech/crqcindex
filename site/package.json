{
  "name": "crqcindex-site",
  "version": "0.1.0",
  "description": "CRQC Index - Cryptographically Relevant Quantum Computation monitoring and signal analysis",
  "type": "module",
  "scripts": {
    "restore": "dotnet restore",
    "fable": "dotnet fable . --exclude Partas.Solid.FablePlugin --noCache -o output -e .fs.jsx -c Release",
    "fable:watch": "dotnet fable watch . --exclude Partas.Solid.FablePlugin --noCache -o output -e .fs.jsx -c Release",
    "dev": "npm run fable && vite",
    "dev:watch": "concurrently \"npm run fable:watch\" \"vite\"",
    "build": "npm run fable && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.36.0",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.16.1",
    "solid-js": "^1.8.0",
    "solid-marked": "^0.6.3",
    "vite-plugin-solid-marked": "^0.6.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vite-plugin-solid": "^2.8.0"
  },
  "keywords": [
    "crqc",
    "quantum",
    "cryptography",
    "fsharp",
    "solid-js",
    "post-quantum"
  ],
  "author": "SpeakEZ Technologies",
  "license": "UNLICENSED"
}
